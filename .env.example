# Copy to .env and fill in. Both the agent and the bench harness read these at
# startup (via python-dotenv) when you run the eval from this directory.

# --- Agent (the system under test) ---
# Default Claude model. Swap to anthropic/claude-sonnet-4-6, openai/gpt-..., etc.
PEICO_AGENT_MODEL=anthropic/claude-opus-4-8
# PEICO_MAX_TOOL_ITERS=12

# --- Provider credentials (only the one your model needs) ---
ANTHROPIC_API_KEY=
# OPENAI_API_KEY=
# GEMINI_API_KEY=

# --- Bench harness (customer simulator + judge; pinned, cheap by default) ---
# These belong to peico-bench, not the agent; set here only to override a local run.
# PEICO_SIM_MODEL=anthropic/claude-haiku-4-5
# PEICO_JUDGE_MODEL=anthropic/claude-haiku-4-5
# Override the world DB path (defaults to the installed peico-bench's out/peico.sqlite).
# PEICO_DB_PATH=
