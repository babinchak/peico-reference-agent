# Copy to .env and fill in. The agent reads these at startup (via python-dotenv).

# --- Model (LiteLLM model string; provider-prefixed) ---
# Default Claude model. Swap to anthropic/claude-sonnet-4-6, openai/gpt-..., etc.
PEICO_AGENT_MODEL=anthropic/claude-opus-4-8

# The eval simulator + judge aren't the system-under-test, so they default to a
# cheap model. Override here or per-run with --sim-model / --judge-model.
# PEICO_SIM_MODEL=anthropic/claude-haiku-4-5
# PEICO_JUDGE_MODEL=anthropic/claude-haiku-4-5

# --- Provider credentials (only the one your model needs) ---
ANTHROPIC_API_KEY=
# OPENAI_API_KEY=
# GEMINI_API_KEY=

# --- World location (the peico-bench dataset) ---
# Defaults to ../peico-bench relative to this repo if unset.
# PEICO_BENCH_ROOT=C:/Users/conne/dev/peico-bench
# Overrides the DB path directly (defaults to <bench>/out/peico.sqlite).
# PEICO_DB_PATH=

# --- Loop tuning ---
# PEICO_MAX_TOOL_ITERS=12
